{
  "compilerOptions": {
      "target": "es2022",
      "module": "esnext",
      "strict": true,
      "noImplicitAny": true,
      "moduleResolution": "node",
      "esModuleInterop": true,
      "experimentalDecorators": true,
      "emitDecoratorMetadata": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "removeComments": true,
      "composite": true,
      "incremental": true,
      "rootDir": "src",
      "baseUrl": ".",
      "paths": {
        "src/*": ["src/*"],
        "@/*": ["src/*"]
      },
      "allowJs": true,
  "types": ["node", "vite/client"]
  },
  "include": [
      "src"
  ],
  "exclude": [
    "./dist",
    "./node_modules",
  ]
}
